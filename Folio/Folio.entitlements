<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox (required for Mac App Store) -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Outgoing network connections — required for AI API calls (OpenAI, Anthropic, Groq) -->
	<key>com.apple.security.network.client</key>
	<true/>

	<!-- Read+write access to files the user explicitly opens or saves via open/save panels.
	     This covers all PDFs the user selects — Desktop and Documents are included
	     automatically when the user picks files from those locations. No broader
	     filesystem entitlement is needed (and none would be approved for MAS). -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
